{
  "id": "weclawbot",
  "name": "WeClawBot Bridge",
  "description": "OpenClaw channel plugin for WeClawBot-Bridge — connects WeChat through the Bridge WS Remote Agent protocol",
  "version": "0.1.0",
  "channels": ["weclawbot"],
  "activation": {
    "onStartup": true
  },
  "channelEnvVars": {
    "weclawbot": [
      "WECLAWBOT_TOKEN",
      "WECLAWBOT_BRIDGE_URL",
      "WECLAWBOT_AGENT_ID"
    ]
  },
  "channelConfigs": {
    "weclawbot": {
      "schema": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "token": { "type": "string" },
          "bridgeUrl": { "type": "string" },
          "agentId": { "type": "string" },
          "agentName": { "type": "string" },
          "command": { "type": "string" },
          "allowFrom": { "type": "array", "items": { "type": "string" } }
        }
      },
      "uiHints": {
        "token": { "label": "WS Token", "sensitive": true },
        "bridgeUrl": { "label": "Bridge URL" },
        "agentId": { "label": "Agent ID" },
        "agentName": { "label": "Agent Name" },
        "command": { "label": "Command Alias" }
      }
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": true,
    "properties": {}
  }
}
